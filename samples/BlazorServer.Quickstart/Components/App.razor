@inject IOptions<TapInAuthOptions> AuthOptions
@{
    var auth = AuthOptions.Value;
}
<!DOCTYPE html>
<html lang="en" data-theme="@auth.Theme.Mode.ToString().ToLowerInvariant()">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <base href="/" />
    <link rel="stylesheet" href="/_content/TapInAuth.UI/tapinauth-theme.css" />
    <HeadOutlet />
    <script>
        (function () {
            try {
                var saved = localStorage.getItem("tapinauth.theme");
                if (saved === "light" || saved === "dark" || saved === "auto") {
                    document.documentElement.setAttribute("data-theme", saved);
                }
            } catch (_) {}
        })();
    </script>
    <style>
        :root, :root[data-theme="light"] {
            --tap-bg:      @auth.Theme.BackgroundLight;
            --tap-surface: @auth.Theme.SurfaceLight;
        }
        @@media (prefers-color-scheme: dark) {
            :root[data-theme="auto"] {
                --tap-bg:      @auth.Theme.BackgroundDark;
                --tap-surface: @auth.Theme.SurfaceDark;
            }
        }
        :root[data-theme="dark"] {
            --tap-bg:      @auth.Theme.BackgroundDark;
            --tap-surface: @auth.Theme.SurfaceDark;
        }
    </style>
</head>
<body class="tap-body">
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script src="/_content/TapInAuth.UI/tapinauth-passkey.js"></script>
    <script src="/_content/TapInAuth.UI/tapinauth-theme.js"></script>
</body>
</html>
