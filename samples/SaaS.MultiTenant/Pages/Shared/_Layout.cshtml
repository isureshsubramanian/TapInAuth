@inject Microsoft.Extensions.Options.IOptions<TapInAuthOptions> AuthOptions
@inject ITenantResolver TenantResolver
@{
    var auth = AuthOptions.Value;
    var tenant = (await TenantResolver.ResolveAsync(Context.RequestAborted)) ?? TenantContext.Default;
    var accent   = !string.IsNullOrEmpty(tenant.ThemeAccent) ? tenant.ThemeAccent : auth.Theme.Accent;
    var logoPath = !string.IsNullOrEmpty(tenant.LogoPath)    ? tenant.LogoPath    : auth.Logo.Path;
    var brand = tenant.DisplayName ?? "TapInAuth SaaS";

    var route = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var isHome = route.EndsWith("/Index", StringComparison.Ordinal);
    var isPasskeys = route.EndsWith("/Passkeys", StringComparison.Ordinal);
    var isRecovery = route.EndsWith("/Recovery", StringComparison.Ordinal);
    var passkeysEnabled = (auth.Methods & TapInAuthMethod.Passkey) != 0;
    var recoveryEnabled = (auth.Methods & TapInAuthMethod.RecoveryCode) != 0;
    var isAdmin = User.IsInRole(auth.Security.AdminRole);
    var name = User.Identity?.Name ?? "";
}
<!DOCTYPE html>
<html lang="en" data-theme="@auth.Theme.Mode.ToString().ToLowerInvariant()">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>@(ViewData["Title"] ?? brand)</title>
    <link rel="stylesheet" href="~/_content/TapInAuth.UI/tapinauth-theme.css" asp-append-version="true" />
    <script>
        (function () {
            try {
                var saved = localStorage.getItem("tapinauth.theme");
                if (saved === "light" || saved === "dark" || saved === "auto") {
                    document.documentElement.setAttribute("data-theme", saved);
                }
            } catch (_) {}
        })();
    </script>
    <style>
        :root {
            --tap-accent:      @accent;
            --tap-radius:      @auth.Theme.Radius;
            --tap-card-radius: @auth.Theme.CardRadius;
            --tap-font:        @Html.Raw(auth.Theme.FontFamily);
        }
        :root, :root[data-theme="light"] {
            --tap-bg:      @auth.Theme.BackgroundLight;
            --tap-surface: @auth.Theme.SurfaceLight;
        }
        @@media (prefers-color-scheme: dark) {
            :root[data-theme="auto"] {
                --tap-bg:      @auth.Theme.BackgroundDark;
                --tap-surface: @auth.Theme.SurfaceDark;
            }
        }
        :root[data-theme="dark"] {
            --tap-bg:      @auth.Theme.BackgroundDark;
            --tap-surface: @auth.Theme.SurfaceDark;
        }
    </style>
</head>
<body class="tap-body">
    <header class="tap-appbar">
        <a class="tap-appbar-brand" href="/">
            @if (!string.IsNullOrEmpty(logoPath))
            {
                <img src="@Url.Content("~/" + logoPath.TrimStart('/'))" alt="@brand" />
            }
            else
            {
                <span>@brand</span>
            }
        </a>
        <nav class="tap-appbar-nav">
            <a href="/" class="@(isHome ? "active" : "")">Home</a>
            @if (passkeysEnabled)
            {
                <a href="/passkeys" class="@(isPasskeys ? "active" : "")">Passkeys</a>
            }
            @if (recoveryEnabled)
            {
                <a href="/recovery" class="@(isRecovery ? "active" : "")">Recovery</a>
            }
            @if (isAdmin)
            {
                <a href="/auth/admin">Admin</a>
            }
            <a href="/hermex">Inbox</a>
            <button type="button" class="tap-theme-toggle" aria-label="Toggle theme">🌓 Auto</button>
            <a href="/auth/sign-out" title="Sign out @name">Sign out</a>
        </nav>
    </header>
    <main class="tap-container">
        @RenderBody()
    </main>
    @if (passkeysEnabled)
    {
        <script src="~/_content/TapInAuth.UI/tapinauth-passkey.js" asp-append-version="true"></script>
    }
    <script src="~/_content/TapInAuth.UI/tapinauth-theme.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
