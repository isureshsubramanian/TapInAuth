@inject Microsoft.Extensions.Options.IOptions<TapInAuth.Options.TapInAuthOptions> Options
@inject TapInAuth.Tenancy.ITenantResolver TenantResolver
@{
    var o = Options.Value;
    // Per-tenant overrides: a SaaS host's ITenantResolver can return tenant.ThemeAccent / tenant.LogoPath,
    // and we apply those here so the sign-in card matches the tenant's brand instead of the global default.
    var tenant = (await TenantResolver.ResolveAsync(Context.RequestAborted)) ?? TapInAuth.TenantContext.Default;
    var accent   = !string.IsNullOrEmpty(tenant.ThemeAccent) ? tenant.ThemeAccent : o.Theme.Accent;
    var logoPath = !string.IsNullOrEmpty(tenant.LogoPath)    ? tenant.LogoPath    : o.Logo.Path;
    var altText  = tenant.DisplayName ?? o.Logo.AltText ?? "Logo";
}
<!DOCTYPE html>
<html lang="en" data-theme="@o.Theme.Mode.ToString().ToLowerInvariant()">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>@(ViewData["Title"] ?? "Sign in")</title>
    <link rel="stylesheet" href="~/_content/TapInAuth.UI/tapinauth-theme.css" asp-append-version="true" />
    @* Apply the user's saved theme BEFORE the body paints to avoid a flash. *@
    <script>
        (function () {
            try {
                var saved = localStorage.getItem("tapinauth.theme");
                if (saved === "light" || saved === "dark" || saved === "auto") {
                    document.documentElement.setAttribute("data-theme", saved);
                }
            } catch (_) {}
        })();
    </script>
    @* Per-host overrides for the design tokens (accent, radius, fonts, etc.). *@
    <style>
        :root {
            --tap-accent:      @accent;
            --tap-radius:      @o.Theme.Radius;
            --tap-card-radius: @o.Theme.CardRadius;
            --tap-font:        @Html.Raw(o.Theme.FontFamily);
        }
        :root, :root[data-theme="light"] {
            --tap-bg:      @o.Theme.BackgroundLight;
            --tap-surface: @o.Theme.SurfaceLight;
        }
        @@media (prefers-color-scheme: dark) {
            :root[data-theme="auto"] {
                --tap-bg:      @o.Theme.BackgroundDark;
                --tap-surface: @o.Theme.SurfaceDark;
            }
        }
        :root[data-theme="dark"] {
            --tap-bg:      @o.Theme.BackgroundDark;
            --tap-surface: @o.Theme.SurfaceDark;
        }
    </style>
</head>
<body class="tap-body tap-auth-page">
    <main class="tap-card" role="main">
        @if (!string.IsNullOrEmpty(logoPath))
        {
            @* SVG logos can use fill="currentColor" to inherit the brand accent. *@
            <div class="tap-logo" style="color: var(--tap-accent);">
                <img src="@Url.Content("~/" + logoPath.TrimStart('/'))" alt="@altText" />
            </div>
        }
        @RenderBody()
        <p class="tap-foot" style="display:flex; justify-content:space-between; align-items:center;">
            <span>Secured by <a class="tap-link" href="https://tapinauth.io">TapInAuth</a></span>
            <button type="button" class="tap-theme-toggle" aria-label="Toggle theme">🌓 Auto</button>
        </p>
    </main>
    <script src="~/_content/TapInAuth.UI/tapinauth-theme.js" asp-append-version="true"></script>
    @if ((o.Methods & TapInAuth.TapInAuthMethod.Passkey) != 0)
    {
        <script src="~/_content/TapInAuth.UI/tapinauth-passkey.js" asp-append-version="true"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Segmented OTP input: auto-advance + paste support.
        document.addEventListener("input", function (e) {
            var t = e.target;
            if (!t.matches(".tap-otp input")) return;
            t.value = t.value.replace(/\D/g, "").slice(0, 1);
            if (t.value && t.nextElementSibling) t.nextElementSibling.focus();
            var inputs = t.parentElement.querySelectorAll("input");
            var hidden = document.getElementById("otp-code");
            if (hidden) hidden.value = Array.from(inputs).map(function (x) { return x.value; }).join("");
        });
        document.addEventListener("paste", function (e) {
            var t = e.target;
            if (!t.matches(".tap-otp input")) return;
            var data = (e.clipboardData || window.clipboardData).getData("text").replace(/\D/g, "");
            if (!data) return;
            e.preventDefault();
            var inputs = t.parentElement.querySelectorAll("input");
            inputs.forEach(function (inp, i) { inp.value = data[i] || ""; });
            var hidden = document.getElementById("otp-code");
            if (hidden) hidden.value = data.slice(0, inputs.length);
            (inputs[Math.min(data.length, inputs.length - 1)] || inputs[0]).focus();
        });
    </script>
</body>
</html>
